---
import { siteConfig } from '../data/siteConfig';
---
<section class="cta">
  <div class="cta-inner">
    <h2>Full documentation</h2>
    <p>
      The complete case descriptions, methodology notes, and implementation details
      are available in the project documentation.
    </p>
    <a href={siteConfig.docsUrl} class="cta-button" target="_blank" rel="noopener noreferrer">
      Read the full documentation →
    </a>
  </div>
</section>

<style>
  .cta {
    background: var(--color-bg);
    padding: var(--space-8) var(--space-3);
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta h2 {
    margin-bottom: var(--space-2);
  }

  .cta p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .cta-button {
    display: inline-block;
    background: var(--color-accent);
    color: #ffffff;
    text-decoration: none;
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    transition: opacity 0.15s;
  }

  .cta-button:hover {
    opacity: 0.85;
  }
</style>
