---
import { siteConfig } from '../data/siteConfig';
---
<section class="hero">
  <div class="hero-inner">
    <p class="hero-label">{siteConfig.conference}</p>
    <h1>{siteConfig.title}</h1>
    <p class="hero-subtitle">{siteConfig.organization} · {siteConfig.orgFull}</p>
    <a href="#summary" class="hero-scroll" aria-label="Scroll to explore the six AI use cases">Explore the cases ↓</a>
  </div>
</section>

<style>
  .hero {
    background: var(--color-bg-dark);
    color: #ffffff;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: var(--space-8) var(--space-3);
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  .hero-label {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: var(--space-3);
    max-width: none;
  }

  .hero h1 {
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: var(--space-3);
    color: #ffffff;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-6);
    max-width: none;
  }

  .hero-scroll {
    display: inline-block;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.625rem 1.25rem;
    border-radius: 6px;
    font-size: 0.9375rem;
    transition: background 0.15s;
  }

  .hero-scroll:hover {
    background: rgba(255, 255, 255, 0.1);
  }
</style>
